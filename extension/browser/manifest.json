{
	"manifest_version": 3,
	"name": "MCPMate",
	"short_name": "MCPMate",
	"version": "0.3.3",
	"description": "Discover curated MCP resources and send detected MCP snippets to MCPMate desktop.",
	"homepage_url": "https://mcp.umate.ai",
	"minimum_chrome_version": "114",
	"permissions": [
		"storage"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"icons": {
		"16": "icons/icon-16.png",
		"32": "icons/icon-32.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	},
	"action": {
		"default_title": "MCPMate",
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon-16.png",
			"32": "icons/icon-32.png",
			"48": "icons/icon-48.png",
			"128": "icons/icon-128.png"
		}
	},
	"content_scripts": [
		{
			"matches": [
				"<all_urls>"
			],
			"exclude_matches": [
				"*://*/*.svg",
				"*://*/*.png",
				"*://*/*.jpg",
				"*://*/*.jpeg",
				"*://*/*.gif",
				"*://*/*.webp",
				"*://*/*.ico",
				"*://*/*.bmp",
				"*://*/*.avif",
				"*://*/*.pdf",
				"*://*/*.json",
				"*://*/*.css",
				"*://*/*.js",
				"*://*/*.mjs",
				"*://*/*.xml",
				"*://*/*.woff",
				"*://*/*.woff2",
				"*://*/*.ttf",
				"*://*/*.eot",
				"*://*/*.mp4",
				"*://*/*.webm",
				"*://*/*.mp3",
				"*://*/*.wav",
				"*://*/*.zip",
				"*://*/*.gz"
			],
			"js": [
				"cursor-deeplink.js",
				"content.js"
			],
			"run_at": "document_idle"
		},
		{
			"matches": [
				"<all_urls>"
			],
			"exclude_matches": [
				"*://*/*.svg",
				"*://*/*.png",
				"*://*/*.jpg",
				"*://*/*.jpeg",
				"*://*/*.gif",
				"*://*/*.webp",
				"*://*/*.ico",
				"*://*/*.bmp",
				"*://*/*.avif",
				"*://*/*.pdf",
				"*://*/*.json",
				"*://*/*.css",
				"*://*/*.js",
				"*://*/*.mjs",
				"*://*/*.xml",
				"*://*/*.woff",
				"*://*/*.woff2",
				"*://*/*.ttf",
				"*://*/*.eot",
				"*://*/*.mp4",
				"*://*/*.webm",
				"*://*/*.mp3",
				"*://*/*.wav",
				"*://*/*.zip",
				"*://*/*.gz"
			],
			"js": [
				"theme-bridge.js"
			],
			"run_at": "document_idle"
		}
	],
	"background": {
		"service_worker": "background.js"
	}
}