[
  {
    "server": "playwright",
    "tool": "playwright_navigate",
    "arguments": {
      "url": "https://modelcontextprotocol.io",
      "width": 1280,
      "height": 800,
      "headless": true
    }
  },
  {
    "server": "playwright",
    "tool": "playwright_screenshot",
    "arguments": {
      "name": "screenshot",
      "fullPage": true,
      "storeBase64": true
    }
  },
  {
    "server": "playwright",
    "tool": "playwright_close",
    "arguments": {}
  }
]