// Trae desktop client template definition
{
  identifier: "trae",
  display_name: "Trae",
  format: "json",
  protocol_revision: "2025-06-18",
  metadata: {
    logo_url: "https://lf-cdn.trae.ai/obj/trae-ai-us/trae_website_prod/favicon.png",
    category: "application",
    description: "Understand. Execute. Deliver. TRAE is your 10x AI Engineer who can independently build software solutions for you.",
    homepage_url: "https://trae.ai",
    docs_url: "https://docs.trae.ai/",
    support_url: "https://discord.gg/NV3MF24tAe",
  },
  storage: {
    kind: "file",
    path_strategy: "config_path",
  },
  detection: {
    macos: [
      {
        method: "config_path",
        value: "~/Library/Application Support/Trae/User/mcp.json",
      },
    ],
  },
  config_mapping: {
    container_keys: ["mcpServers"],
    container_type: "object_map",
    merge_strategy: "replace",
    keep_original_config: true,
    managed_source: "profile",
    format_rules: {
      stdio: {
        template: {
          type: "stdio",
          command: "{{command}}",
          args: "{{{json args}}}",
          env: "{{{json env}}}",
        },
        requires_type_field: false,
      },
      sse: {
        template: {
          type: "sse",
          url: "{{url}}",
          headers: "{{{json headers}}}",
        },
        requires_type_field: false,
      },
      streamable_http: {
        template: {
          type: "streamable_http",
          url: "{{url}}",
        },
        requires_type_field: false,
      },
    },
  },
}
