// DeepChat desktop client template definition
{
  identifier: "deepchat",
  display_name: "DeepChat",
  format: "json",
  protocol_revision: "2025-06-18",
  metadata: {
    logo_url: "https://deepchat.thinkinai.xyz/logo.png",
    category: "application",
    supported_runtimes: {
      macos: ["npx", "uvx", "docker", "binary"],
      linux: ["npx", "uvx", "docker", "binary"],
      windows: ["npx", "uvx", "binary"],
    },
  },
  storage: {
    kind: "file",
    path_strategy: "config_path",
  },
  detection: {
    macos: [
      {
        method: "config_path",
        value: "~/Library/Application Support/DeepChat/mcp-settings.json",
      },
    ],
  },
  config_mapping: {
    container_key: "mcpServers",
    container_type: "object_map",
    merge_strategy: "replace",
    keep_original_config: true,
    managed_source: "profile",
    format_rules: {
      stdio: {
        template: {
          type: "stdio",
          command: "{{command}}",
          args: "{{{json args}}}",
          env: "{{{json env}}}",
        },
        requires_type_field: false,
      },
      sse: {
        template: {
          type: "sse",
          url: "{{url}}",
          headers: "{{{json headers}}}",
        },
        requires_type_field: false,
      },
      streamable_http: {
        template: {
          type: "streamable_http",
          url: "{{url}}",
        },
        requires_type_field: false,
      },
    },
  },
}
