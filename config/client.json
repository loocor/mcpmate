{
  "version": "2025.05.31.001",
  "clients": [
    {
      "identifier": "claude_desktop",
      "display_name": "Claude Desktop",
      "detection_rules": {
        "macos": [
          {
            "method": "bundle_id",
            "value": "com.anthropic.claudefordesktop",
            "config_path": "~/Library/Application Support/Claude/claude_desktop_config.json",
            "priority": 1
          },
          {
            "method": "file_path",
            "value": "/Applications/Claude.app",
            "config_path": "~/Library/Application Support/Claude/claude_desktop_config.json",
            "priority": 2
          }
        ],
        "windows": [
          {
            "method": "file_path",
            "value": "~/AppData/Roaming/Claude/claude_desktop_config.json",
            "priority": 1
          }
        ]
      },
      "config_rules": {
        "is_mixed_config": true,
        "top_level_key": "mcpServers",
        "supported_transports": [
          "stdio"
        ],
        "supported_runtimes": {
          "macos": [
            "npx",
            "uvx",
            "docker",
            "binary"
          ],
          "linux": [
            "npx",
            "uvx",
            "docker",
            "binary"
          ],
          "windows": [
            "npx",
            "uvx",
            "binary"
          ]
        },
        "format_rules": {
          "stdio": {
            "template": {
              "command": "{{command}}",
              "args": "{{args}}",
              "env": "{{env}}"
            },
            "requires_type_field": false
          }
        }
      }
    },
    {
      "identifier": "windsurf",
      "display_name": "Windsurf",
      "detection_rules": {
        "macos": [
          {
            "method": "file_path",
            "value": "/Applications/Windsurf.app",
