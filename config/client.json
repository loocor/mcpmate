            "priority": 1
          }
        ]
      },
      "config_rules": {
        "top_level_key": "mcpServers",
        "is_mixed_config": false,
        "supported_transports": [
          "stdio",
          "sse"
        ],
        "supported_runtimes": {
          "macos": [
            "npx",
            "uvx",
            "docker",
            "binary"
          ],
          "linux": [
            "npx",
            "uvx",
            "docker",
            "binary"
          ],
          "windows": [
            "npx",
            "uvx",
            "binary"
          ]
        },
        "format_rules": {
          "stdio": {
            "template": {
              "type": "stdio",
              "command": "{{command}}",
              "args": "{{args}}",
              "env": "{{env}}"
            },
            "requires_type_field": true
          },
          "sse": {
            "template": {
              "serverUrl": "{{url}}",
              "headers": "{{headers}}"
            },
            "requires_type_field": false
          }
        },
        "security_features": {
          "supports_inputs": true,
          "supports_env_file": true
        }
