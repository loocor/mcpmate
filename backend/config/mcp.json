{
	"mcpServers": {
		"21Magic": {
			"args": [
				"-y",
				"@21st-dev/magic@latest",
				"API_KEY=\"REPLACE_WITH_YOUR_21MAGIC_API_KEY\""
			],
			"command": "npx",
			"type": "stdio"
		},
		"Context7": {
			"args": [
				"-y",
				"@upstash/context7-mcp@latest"
			],
			"command": "npx",
			"type": "stdio"
		},
		"Devtools": {
			"command": "npx",
			"type": "stdio",
			"args": [
				"chrome-devtools-mcp@latest"
			]
		},
		"Deepwiki": {
			"args": [
				"-y",
				"mcp-deepwiki@latest"
			],
			"command": "npx",
			"type": "stdio"
		},
		"Everything": {
			"args": [
				"-y",
				"@modelcontextprotocol/server-everything"
			],
			"command": "npx",
			"type": "stdio"
		},
		"Fetch": {
			"args": [
				"mcp-server-fetch"
			],
			"command": "uvx",
			"type": "stdio"
		},
		"Gitmcp": {
			"url": "https://gitmcp.io/modelcontextprotocol/rust-sdk",
			"type": "streamable_http"
		},
		"Playwright": {
			"args": [
				"-y",
				"@playwright/mcp@latest",
				"--extension"
			],
			"command": "npx",
			"type": "stdio"
		},
		"Thinking": {
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			],
			"command": "bunx",
			"env": {},
			"type": "stdio"
		}
	}
}
