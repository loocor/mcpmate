// Claude Code client template definition
{
  identifier: "claude_code",
  display_name: "Claude Code",
  format: "json",
  metadata: {
    category: "application",
    description: "Unleash Claude’s raw power directly in your terminal. Search million-line codebases instantly.",
    docs_url: "https://docs.claude.com/en/docs/claude-code/overview",
    homepage_url: "https://www.claude.com/product/claude-code",
    logo_url: "https://claude.ai/favicon.ico",
    support_url: "https://support.claude.com",
  },
  storage: {
    kind: "file",
    path_strategy: "config_path",
  },
  detection: {
    macos: [
      {
        method: "config_path",
        value: "~/.claude.json",
      }
    ],
    windows: [
      {
        method: "config_path",
        value: "~/AppData/Roaming/Claude/.claude.json",
      }
    ],
  },
  config_mapping: {
    container_keys: ["mcpServers"],
    container_type: "object_map",
    merge_strategy: "replace",
    keep_original_config: true,
    managed_source: "profile",
    format_rules: {
      stdio: {
        template: {
          type: "stdio",
          command: "{{command}}",
          args: "{{{json args}}}",
          env: "{{{json env}}}",
        },
        requires_type_field: false,
      },
      sse: {
        template: {
          type: "sse",
          url: "{{url}}",
          headers: "{{{json headers}}}",
        },
        requires_type_field: false,
      },
      streamable_http: {
        template: {
          type: "http",
          url: "{{url}}",
          headers: "{{{json headers}}}",
        },
        requires_type_field: false,
      },
    },
  },
}
