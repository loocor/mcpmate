// CodeBuddy desktop client template definition
{
  identifier: "codebuddy",
  display_name: "CodeBuddy",
  format: "json",
  metadata: {
    category: "application",
    description: "Harnessed for productivity. Designed for collaboration. Celebrated for built-in security. Welcome to the platform developers love..",
    homepage_url: "https://www.codebuddy.ai/",
    logo_url: "https://codebuddy-1328495429.cos.accelerate.myqcloud.com/web/ide/icon.png",
    support_url: "https://discord.gg/cWTkReTh8N",
  },
  storage: {
    kind: "file",
    path_strategy: "config_path",
  },
  detection: {
    macos: [
      {
        method: "config_path",
        value: "~/Library/Application Support/CodeBuddy/User/globalStorage/tencent.planning-genie/settings/codebuddy_mcp_settings.json",
      },
    ],
    windows: [
      {
        method: "config_path",
        value: "~/AppData/Roaming/CodeBuddy/User/globalStorage/tencent.planning-genie/settings/codebuddy_mcp_settings.json",
      },
    ],
  },
  config_mapping: {
    container_keys: ["mcpServers"],
    container_type: "object_map",
    merge_strategy: "replace",
    keep_original_config: true,
    managed_source: "profile",
    format_rules: {
      stdio: {
        template: {
          type: "stdio",
          command: "{{command}}",
          args: "{{{json args}}}",
          env: "{{{json env}}}",
        },
        requires_type_field: false,
      },
      sse: {
        template: {
          type: "sse",
          url: "{{{url}}}",
          headers: "{{{json headers}}}",
        },
        requires_type_field: false,
      },
      streamable_http: {
        template: {
          type: "http",
          url: "{{{url}}}",
          headers: "{{{json headers}}}",
        },
        requires_type_field: false,
      },
    },
  },
}
