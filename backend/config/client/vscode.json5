// VS Code MCP configuration template
{
  identifier: "vscode",
  display_name: "VS Code",
  format: "json",
  metadata: {
    category: "application",
    description: "Visual Studio Code with MCP extension support for AI-assisted tooling.",
    docs_url: "https://code.visualstudio.com/docs",
    homepage_url: "https://code.visualstudio.com",
    logo_url: "https://code.visualstudio.com/assets/favicon.ico",
    support_url: "https://code.visualstudio.com/docs/supporting/faq",
  },
  storage: {
    kind: "file",
    path_strategy: "config_path",
  },
  detection: {
    macos: [
      {
        method: "config_path",
        value: "~/Library/Application Support/Code/User/mcp.json",
      },
    ],
    windows: [
      {
        method: "config_path",
        value: "~/AppData/Roaming/Code/User/mcp.json",
      },
    ],
  },
  config_mapping: {
    container_keys: [
      "servers",
      "mcp.servers"
    ],
    container_type: "object_map",
    merge_strategy: "replace",
    keep_original_config: true,
    managed_source: "profile",
    format_rules: {
      stdio: {
        template: {
          type: "stdio",
          command: "{{command}}",
          args: "{{{json args}}}",
          env: "{{{json env}}}",
        },
        requires_type_field: false,
      },
      sse: {
        template: {
          url: "{{{url}}}",
          type: "sse",
          headers: "{{{json headers}}}",
        },
        requires_type_field: false,
      },
      streamable_http: {
        template: {
          type: "http",
          headers: "{{{json headers}}}",
          url: "{{{url}}}",
        },
        requires_type_field: false,
      },
    },
  },
}
