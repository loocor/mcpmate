{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "MCPMate",
	"version": "0.0.0-dev",
	"identifier": "desktop.mcp.umate.ai",
	"build": {
		"devUrl": "http://127.0.0.1:5173",
		"frontendDist": "../../board/dist",
		"beforeDevCommand": {
			"cwd": "../../board",
			"script": "(command -v bun >/dev/null 2>&1 && bun run dev -- --host 127.0.0.1 --port 5173 || npm run dev -- --host 127.0.0.1 --port 5173)",
			"wait": false
		},
		"beforeBuildCommand": {
			"cwd": "../../board",
			"script": "(command -v bun >/dev/null 2>&1 && bun run build || npm run build)"
		}
	},
	"app": {
		"withGlobalTauri": true,
		"security": {
			"csp": null
		},
		"windows": [
			{
				"label": "main",
				"title": "MCPMate",
				"width": 1280,
				"height": 800,
				"resizable": true,
				"create": false,
				"dragDropEnabled": false,
				"titleBarStyle": "Transparent",
				"hiddenTitle": true
			}
		]
	},
	"bundle": {
		"active": true,
		"targets": ["app", "dmg"],
		"icon": ["icons/icon.icns", "icons/icon.png", "icons/icon.ico"],
		"externalBin": [
			"../../backend/target/sidecars/bridge",
			"../../backend/target/sidecars/mcpmate-core"
		],
		"macOS": {
			"entitlements": "entitlements.plist",
			"minimumSystemVersion": "10.15",
			"signingIdentity": null,
			"providerShortName": null
		}
	},
	"plugins": {
		"opener": {},
		"deep-link": {
			"desktop": {
				"schemes": ["mcpmate"]
			}
		},
		"updater": {
			"active": false,
			"dialog": true,
			"endpoints": [
				"https://github.com/loocor/mcpmate/releases/latest/download/update.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4MTI2ODAwNTEyRTgwMjAKUldRZ2dDNVJBR2dTU1BGNUJxU2Y5SWt4OFJYeGJGTjhkaXhnUDhyeGtJUCtjKzhEMEJYQklyd3cK",
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
