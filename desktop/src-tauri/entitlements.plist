<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow executing external programs (npx, bunx, uv, etc.) -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>

	<!-- Allow spawning child processes -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>

	<!-- Allow network access for MCP servers -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>

	<!-- Allow reading/writing to user home directory -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Allow accessing .mcpmate directory -->
	<key>com.apple.security.files.all</key>
	<true/>

	<!-- Disable App Sandbox for development -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Allow loading dylibs (for backend bridge) -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
