# MCPMate Desktop (Tauri) – Minimal env for signed & notarized DMG (no App Store)
# 复制为 `.env`，只需填下面 4 个值，然后运行：
#   ./script/macos-build-tauri-release.sh

# 必填：Developer ID Application 签名身份（Keychain 名称或证书指纹）
# 示例：Developer ID Application: Your Org (TEAMID1234)
# 或者：0123456789ABCDEF0123456789ABCDEF01234567
APPLE_SIGNING_IDENTITY=

# 必填：Apple ID（用于 notarytool 公证）
APPLE_ID=

# 必填：App 专用密码（四段字母数字）
APPLE_PASSWORD=

# 必填：Apple Developer Team ID（10 位）
APPLE_TEAM_ID=

# （可选）在预览/内测包中保护 OpenAPI：
# 设置后端仅在提供密码时返回 /openapi.json；/docs 页面可见但受保护。
MCPMATE_TAURI_OPENAPI_ENABLED=true
MCPMATE_TAURI_OPENAPI_PASSWORD=terlong

# （可选）预览版到期日（含当日），格式 YYYY-MM-DD。未设置时使用 2025-10-31。
MCPMATE_TAURI_PREVIEW_EXPIRY_DATE="2025-11-09"

# （可选）关闭流式代理，前端回退到 mcpmate:// 协议加载避免白屏
MCPMATE_TAURI_ENABLE_STREAM_PROXY=true

# （可选）开启 cmd + option + i 开启 WKWebView 检视器
MCPMATE_TAURI_ENABLE_INSPECTOR=false
