# Values compiled into the desktop binary (no secrets).
# Edit this file to retarget auth; keep aligned with board `VITE_AUTH_WORKER_BASE` for the bundled dashboard.
# Optional compile-time override: set MCPMATE_AUTH_WORKER_BASE / MCPMATE_KEYCHAIN_SERVICE in the environment
# before `cargo tauri build` (CI or local) — they take precedence over this file.

AUTH_WORKER_BASE=https://auth.mcp.umate.ai
KEYCHAIN_SERVICE=desktop.mcp.umate.ai
