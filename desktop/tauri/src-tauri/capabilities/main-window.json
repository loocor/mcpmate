{
	"$schema": "../gen/schemas/desktop-capability.json",
	"identifier": "main-window",
	"description": "Default capability for the main window to run the MCPMate dashboard",
	"windows": ["main"],
 "permissions": [
   "core:default",
   "opener:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "opener:allow-default-urls"
    }
  ]
}
