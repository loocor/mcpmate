{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"board/**/*.ts",
			"board/**/*.tsx",
			"board/**/*.mts",
			"board/**/*.cts",
			"website/**/*.ts",
			"website/**/*.tsx"
		]
	},
	"formatter": {
		"enabled": false
	},
	"assist": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": false
		}
	}
}
